# Server
PORT=8080
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/streamtorrent

# JWT
JWT_SECRET=change_me_min_32_chars_random_string
JWT_ACCESS_EXPIRES_MIN=15
JWT_TWO_FACTOR_EXPIRES_MIN=10

# Refresh Tokens
REFRESH_EXPIRES_DAYS=30

# Optional — when frontend (film.example.com) and API (api.example.com) are different hosts:
# Use SameSite=None on HTTPS so browsers attach cookies on cross-origin credentialed fetch.
# Set domain to your registrable apex so cookies are visible on both app + API (and Astro middleware).
# AUTH_COOKIE_SAMESITE=none
# AUTH_COOKIE_DOMAIN=.example.com

# DigitalOcean Spaces (S3-compatible object storage)
DO_SPACES_KEY=your_spaces_access_key
DO_SPACES_SECRET=your_spaces_secret_key
DO_SPACES_ENDPOINT=https://ams3.digitaloceanspaces.com
DO_SPACES_REGION=ams3
DO_SPACES_BUCKET=streamtorrent-files
DO_SPACES_CDN_ENDPOINT=   # optional — e.g. https://streamtorrent-files.ams3.cdn.digitaloceanspaces.com

# SMTP — works with any provider (SendGrid, Mailgun, Postmark, etc.)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_smtp_password_or_api_key
SMTP_FROM=noreply@yourdomain.com
SMTP_SECURE=false   # set true only for port 465

# Redis (BullMQ email worker)
REDIS_URL=redis://localhost:6379

# Admin account (seeded on first run)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change_me

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=https://film.bira.pizza,https://streamtorrent-backend-43c4i.ondigitalocean.app
