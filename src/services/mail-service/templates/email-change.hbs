<html>
  <head>
    <meta charset="UTF-8" />
  </head>
  <body
    style="margin:0;padding:0;background:#f4f4f4;font-family:Arial, sans-serif;"
  >
    <table width="100%" cellpadding="0" cellspacing="0" style="padding:40px 0;">
      <tr>
        <td align="center">

          <table
            width="600"
            cellpadding="0"
            cellspacing="0"
            style="background:white;padding:40px;border-radius:10px;"
          >

            <tr>
              <td style="font-size:22px;font-weight:bold;color:#333;">
                E-posta Adresini Değiştir
              </td>
            </tr>

            <tr>
              <td
                style="padding:20px 0;font-size:16px;color:#555;line-height:1.6;"
              >
                {{USERNAME}}, hesabının e-posta adresini
                <b>{{NEW_EMAIL}}</b>
                olarak değiştirmek istiyorsun. Bu işlemi onaylamak için
                aşağıdaki bağlantıya tıklayabilirsin.
              </td>
            </tr>

            <tr>
              <td align="center" style="padding-top:20px;">
                <a
                  href="{{CONFIRM_LINK}}"
                  style="background:#6366f1;color:white;padding:14px 28px;border-radius:8px;
                 text-decoration:none;font-weight:bold;font-size:16px;"
                >
                  E-posta Değişikliğini Onayla
                </a>
              </td>
            </tr>

            <tr>
              <td style="padding-top:30px;font-size:14px;color:#777;">
                Bu bağlantı 30 dakika boyunca geçerlidir.
              </td>
            </tr>

          </table>

        </td>
      </tr>
    </table>
  </body>
</html>