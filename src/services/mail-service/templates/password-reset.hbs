<html>
  <head>
    <meta charset="UTF-8" />
  </head>
  <body style="margin:0;padding:0;background:#f5f5f5;font-family:Arial;">
    <table width="100%" cellpadding="0" cellspacing="0" style="padding:40px 0;">
      <tr>
        <td align="center">

          <table
            width="600"
            cellpadding="0"
            cellspacing="0"
            style="background:white;padding:40px;border-radius:10px;"
          >

            <tr>
              <td style="font-size:22px;font-weight:bold;color:#333;">
                Şifre Sıfırlama Talebi
              </td>
            </tr>

            <tr>
              <td
                style="padding:20px 0;font-size:16px;color:#555;line-height:1.6;"
              >
                {{USERNAME}}, hesabının şifresini sıfırlamak için aşağıdaki
                bağlantıyı kullanabilirsin. Eğer bu talep sana ait değilse bu
                e-postayı görmezden gelebilirsin.
              </td>
            </tr>

            <tr>
              <td align="center" style="padding-top:20px;">
                <a
                  href="{{RESET_LINK}}"
                  style="background:#10b981;color:white;padding:14px 28px;border-radius:8px;
                 font-size:16px;text-decoration:none;font-weight:bold;"
                >
                  Şifreyi Sıfırla
                </a>
              </td>
            </tr>

            <tr>
              <td style="padding-top:30px;font-size:14px;color:#777;">
                Bu bağlantı 30 dakika boyunca geçerlidir.
              </td>
            </tr>

          </table>

        </td>
      </tr>
    </table>
  </body>
</html>