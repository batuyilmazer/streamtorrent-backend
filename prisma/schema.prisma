generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String
  emailVerified     Boolean   @default(false)
  isSuspended       Boolean   @default(false)
  failedLoginCount  Int       @default(0)
  lockUntil         DateTime?
  lastLoginAt       DateTime?
  passwordChangedAt DateTime?
  role              Role      @default(USER)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  refreshTokens          RefreshToken[]
  expiredTwoFactorTokens ExpiredTwoFactorToken[]
  files                  File[]
  torrents               UserTorrent[]
  collections            Collection[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  jti       String   @unique
  tokenHash String
  userAgent String?
  ip        String?
  deviceId  String
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revoked, deviceId])
  @@index([expiresAt])
}

model ExpiredTwoFactorToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  usedAt    DateTime @default(now())
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
  @@index([expiresAt])
}

enum FilePurpose {
  PROFILE_PHOTO
  POST_ATTACHMENT
  DOCUMENT
  OTHER
  TEST_FILE
}

model File {
  id        String      @id @default(uuid())
  purpose   FilePurpose
  key       String      @unique
  bucket    String
  name      String
  mimeType  String
  size      Int
  checksum  String
  isPublic  Boolean     @default(false)
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())

  userId    String?
  user      User?       @relation(fields: [userId], references: [id])
}

model Torrent {
  id            String   @id @default(cuid())
  infoHash      String   @unique
  name          String
  magnetUri     String?
  torrentFile   Bytes?
  size          BigInt
  fileList      Json
  isAdminPinned Boolean  @default(false)
  addedBy       String?
  createdAt     DateTime @default(now())
  lastSeenAt    DateTime @default(now())

  userTorrents    UserTorrent[]
  collectionItems CollectionItem[]
}

model UserTorrent {
  id        String   @id @default(uuid())
  userId    String
  torrentId String
  savedAt   DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  torrent Torrent @relation(fields: [torrentId], references: [id], onDelete: Cascade)

  @@unique([userId, torrentId])
  @@index([userId])
}

model Collection {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CollectionItem[]

  @@index([userId])
}

model CollectionItem {
  id           String   @id @default(uuid())
  collectionId String
  torrentId    String
  addedAt      DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  torrent    Torrent    @relation(fields: [torrentId], references: [id], onDelete: Cascade)

  @@unique([collectionId, torrentId])
  @@index([collectionId])
}